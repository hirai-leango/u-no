rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロフィール: 誰でも読める、自分のものだけ書ける
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // レビュー: 誰でも読める、ログイン済みで自分以外へのみ投稿・編集、自分のものだけ削除
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.fromUserId == request.auth.uid;
    }

    // 公正さ評価(fair/unfair): 誰でも読める、自分の投票だけ作成・削除できる
    match /votes/{voteId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.voterUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.voterUid == request.auth.uid;
    }

    // レビューへのコメント: 誰でも読める、ログイン済みで自分名義のみ作成、自分のものだけ削除
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
    }
  }
}
