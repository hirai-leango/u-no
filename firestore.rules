rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロフィール: 誰でも読める、自分のものだけ書ける
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.slug is string
        && request.resource.data.slug.size() >= 2
        && request.resource.data.slug.size() <= 30
        && request.resource.data.bio.size() <= 200;
    }

    // レビュー: 誰でも読める、ログイン済みで自分以外へのみ投稿・編集、自分のものだけ削除
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() <= 300
        && request.resource.data.relationship in ['boss', 'subordinate', 'colleague', 'client', 'contractor', 'acquaintance', 'other'];
      allow delete: if request.auth != null
        && resource.data.fromUserId == request.auth.uid;
    }

    // 公正さ評価(Good/Bad): 誰でも読める、自分の投票だけ作成・削除できる
    match /votes/{voteId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.voterUid == request.auth.uid
        && request.resource.data.value in ['fair', 'unfair'];
      allow delete: if request.auth != null
        && resource.data.voterUid == request.auth.uid;
    }

    // レビューへのコメント: 誰でも読める、ログイン済みで自分名義のみ作成、自分のものだけ削除
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
    }

    // 通報: 本人は読めない（運営のみ）、ログイン済みで自分名義のみ作成
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 500
        && request.resource.data.targetType in ['review', 'comment'];
      allow update, delete: if false;
    }
  }
}
